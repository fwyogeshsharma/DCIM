# API Configuration
# Point to aggregator service for multi-server monitoring (recommended)
VITE_AGGREGATOR_URL=http://localhost:3002/api/v1

# Fallback to direct server connection (single server mode)
# Use the proxy server for mTLS authentication
VITE_API_URL=http://localhost:3001/api/v1
VITE_AI_API_URL=http://localhost:5000/api

# OpenAI Configuration (for Natural Language Queries)
# VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
