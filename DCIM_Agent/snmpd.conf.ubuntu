###############################################################################
# SNMP Daemon Configuration - Maximum Monitoring
# For Ubuntu Linux Systems
# Copy this file to /etc/snmp/snmpd.conf on your Ubuntu machines
###############################################################################

# Listen on all network interfaces
agentaddress  udp:161

# Community string for read-only access
# IMPORTANT: Change "public" to a secure string in production!
rocommunity public

# System information
sysLocation    "Ubuntu Server - Full Monitoring"
sysContact     admin@example.com

###############################################################################
# DISK MONITORING
###############################################################################

# Monitor root partition with 10% warning threshold
disk / 10%

# Include all mounted disks
includeAllDisks 10%

# If you have separate partitions, add them:
# disk /home 10%
# disk /var 10%

###############################################################################
# LOAD AVERAGE MONITORING
###############################################################################

# Load thresholds: 12 (1min), 10 (5min), 5 (15min)
# Adjust based on your CPU core count
load 12 10 5

###############################################################################
# PROCESS MONITORING
###############################################################################

# Monitor critical system processes
proc sshd
proc cron
proc systemd

###############################################################################
# SYSTEM EXTENSIONS
###############################################################################

# Extended system commands accessible via SNMP
extend uptime /bin/uptime
extend hostname /bin/hostname
extend df /bin/df -h
extend free /usr/bin/free -m
extend netstat /bin/netstat -s

# If lm-sensors is installed, expose temperature data
extend sensors /usr/bin/sensors 2>/dev/null || /bin/true

###############################################################################
# DISK I/O MONITORING
###############################################################################

# Monitor disk I/O for common device names
# Uncomment the lines that match your system

# For traditional SATA/SSD drives
diskio sda
diskio sdb

# For NVMe drives
diskio nvme0n1
diskio nvme0n2

# For virtual machines
diskio vda
diskio vdb

# To find your disk names, run: lsblk

###############################################################################
# CPU, MEMORY, DISK, NETWORK STATISTICS
###############################################################################

# This enables UCD-SNMP-MIB support for detailed system stats
# CPU metrics: 1.3.6.1.4.1.2021.11.*
# Memory metrics: 1.3.6.1.4.1.2021.4.*
# Disk metrics: 1.3.6.1.4.1.2021.9.*
# Load metrics: 1.3.6.1.4.1.2021.10.*

# Network interfaces (MIB-II) are automatically available
# TCP/UDP stats (MIB-II) are automatically available

###############################################################################
# VIEW/ACCESS CONTROL
###############################################################################

# Allow full read access for monitoring
view systemonly included .1

# Default SNMP community configuration
# rocommunity: read-only access
# rwcommunity: read-write access (not recommended for monitoring)

###############################################################################
# LOGGING
###############################################################################

# Log to syslog
# To view logs: sudo journalctl -u snmpd

###############################################################################
# NOTES
###############################################################################

# After editing this file:
# 1. sudo systemctl restart snmpd
# 2. sudo systemctl enable snmpd
# 3. Verify: snmpwalk -v2c -c public localhost 1.3.6.1.4.1.2021

# To test specific metrics:
# CPU: snmpwalk -v2c -c public localhost 1.3.6.1.4.1.2021.11
# Memory: snmpwalk -v2c -c public localhost 1.3.6.1.4.1.2021.4
# Disk: snmpwalk -v2c -c public localhost 1.3.6.1.4.1.2021.9
# Load: snmpwalk -v2c -c public localhost 1.3.6.1.4.1.2021.10

# Security Note:
# - Change "public" community string to something secure
# - Use firewall to restrict SNMP access to monitoring server only:
#   sudo ufw allow from 192.168.1.13 to any port 161 proto udp
#   (Replace 192.168.1.13 with your monitoring machine IP)
