# Network Monitor Agent Configuration

# Server settings
server:
  url: "http://localhost:8080/api/v1"
  timeout: 30s
  retry_attempts: 3
  retry_delay: 5s

# Agent settings
agent:
  # Unique identifier for this agent (auto-generated if empty)
  id: ""
  # Human-readable name for this machine
  name: ""
  # Metrics collection interval
  collect_interval: 60s
  # Normal metrics send interval (batched)
  send_interval: 300s
  # Max metrics to batch in one send
  batch_size: 50

# SNMP Manager settings (query SNMP-enabled devices)
snmp_manager:
  # Enable SNMP device monitoring
  enabled: true  # Set to true to enable
  # How often to poll SNMP devices
  poll_interval: 60s
  # SNMP devices to monitor
  devices:
    # HP 630 Notebook - Ubuntu Linux
    - name: "hp-630-notebook"
      host: "192.168.1.14"
      port: 161
      community: "public"
      version: "2c"  # Options: "1", "2c", "3"
      timeout: 5s
      retries: 3
      oids:
        - oid: "1.3.6.1.2.1.1.3.0"        # System uptime (timeticks)
          name: "uptime"
          type: "counter"
        - oid: "1.3.6.1.2.1.25.1.5.0"     # Number of users logged in
          name: "users"
          type: "gauge"
        - oid: "1.3.6.1.2.1.25.1.6.0"     # Number of processes running
          name: "processes"
          type: "gauge"

    # HP Pavilion Notebook - Ubuntu Linux
    - name: "hp-pavilion-notebook"
      host: "192.168.1.15"
      port: 161
      community: "public"
      version: "2c"
      timeout: 5s
      retries: 3
      oids:
        - oid: "1.3.6.1.2.1.1.3.0"        # System uptime (timeticks)
          name: "uptime"
          type: "counter"
        - oid: "1.3.6.1.2.1.25.1.5.0"     # Number of users logged in
          name: "users"
          type: "gauge"
        - oid: "1.3.6.1.2.1.25.1.6.0"     # Number of processes running
          name: "processes"
          type: "gauge"

# Database settings
database:
  # Path to SQLite database file
  path: "./agent.db"
  # Data retention period
  retention_days: 30

# Alert thresholds
alerts:
  cpu:
    warning: 80.0
    critical: 95.0
  memory:
    warning: 85.0
    critical: 95.0
  disk:
    warning: 85.0
    critical: 95.0
  temperature:
    warning: 75.0
    critical: 85.0

# Logging settings
logging:
  level: "info"  # debug, info, warn, error
  file: "./agent.log"
  max_size_mb: 50
  max_backups: 3
